✅ 3. Linear Search
🔹 Java Code
package com.example;

public class LinearSearch {
    public int search(int[] arr, int key) {
        for (int i = 0; i < arr.length; i++) {
            if (arr[i] == key)
                return i;
        }
        return -1;
    }
}
🔹 JUnit Test
package com.example;

import static org.junit.Assert.assertEquals;
import org.junit.Test;

public class LinearSearchTest {
    @Test
    public void testSearch() {
        LinearSearch ls = new LinearSearch();
        int[] arr = {1, 2, 3, 4};
        assertEquals(2, ls.search(arr, 3));
    }
}
✅ 4. Greatest of 3 Numbers
🔹 Java Code
package com.example;

public class GreatestThree {
    public int findGreatest(int a, int b, int c) {
        return Math.max(a, Math.max(b, c));
    }
}
🔹 JUnit Test
package com.example;

import static org.junit.Assert.assertEquals;
import org.junit.Test;

public class GreatestThreeTest {
    @Test
    public void testGreatest() {
        GreatestThree g = new GreatestThree();
        assertEquals(10, g.findGreatest(10, 5, 3));
    }
}
✅ 5. Bank Account
🔹 Java Code
package com.example;

public class BankAccount {
    private double balance = 0;

    public void deposit(double amount) {
        balance += amount;
    }

    public void withdraw(double amount) {
        balance -= amount;
    }

    public double getBalance() {
        return balance;
    }
}
🔹 JUnit Test
package com.example;

import static org.junit.Assert.assertEquals;
import org.junit.Test;

public class BankAccountTest {
    @Test
    public void testBank() {
        BankAccount acc = new BankAccount();
        acc.deposit(100);
        acc.withdraw(40);
        assertEquals(60, acc.getBalance(), 0.01);
    }
}
✅ 6. Greatest of 2 Numbers
🔹 Java Code
package com.example;

public class GreatestTwo {
    public int max(int a, int b) {
        return (a > b) ? a : b;
    }
}
🔹 JUnit Test
package com.example;

import static org.junit.Assert.assertEquals;
import org.junit.Test;

public class GreatestTwoTest {
    @Test
    public void testMax() {
        GreatestTwo g = new GreatestTwo();
        assertEquals(8, g.max(8, 3));
    }
}




